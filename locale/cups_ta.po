#: systemv/cupsctl.c:235
msgid "--[no-]remote-any       Allow/prevent access from the Internet"
msgstr "--[no-]தொலைவில்-இணையத்திலிருந்து அணுகலை அனுமதிக்கவும்/தடுக்கவும்"

#: systemv/cupsctl.c:236
msgid "--[no-]share-printers   Turn printer sharing on/off"
msgstr "--[no-]share-printers அச்சுப்பொறி பகிர்வை இயக்க/முடக்கு"

#: systemv/cupsctl.c:237
msgid "--[no-]user-cancel-any  Allow/prevent users to cancel any job"
msgstr ""
"--[no-]user-cancel-any எந்த வேலையையும் ரத்து செய்ய பயனர்களை அனுமதிக்கவும்/தடுக்கவும்"

#: tools/ipptool.c:6595
msgid ""
"--bearer-token BEARER-TOKEN\n"
"                        Set the OAuth Bearer token for authentication"
msgstr ""
"--தாங்கி-டோக்கன் தாங்கி-டோக்கன் \n"
"அங்கீகாரத்திற்காக OAuth தாங்கி கிள்ளாக்கை அமைக்கவும்"

#: tools/ipptool.c:6597
msgid ""
"--client-name CLIENT-NAME\n"
"                        Set the TLS client certificate name"
msgstr ""
"--வாடிக்கையாளர்-பெயர் கிளையன்ட்-NAME \n"
"TLS கிளையன்ட் சான்றிதழ் பெயரை அமைக்கவும்"

#: systemv/lpinfo.c:500
msgid "--device-id device-id   Show models matching the given IEEE 1284 device ID"
msgstr ""
"--device-id device-id கொடுக்கப்பட்ட IEEE 1284 சாதன ஐடியுடன் பொருந்தும் மாதிரிகளைக் "
"காட்டு"

#: tools/ippfind.c:2002
msgid "--domain regex          Match domain to regular expression"
msgstr "--domain வழக்கவெளி          Match domain பெறுநர் regular கோவை"

#: systemv/lpinfo.c:501
msgid ""
"--exclude-schemes scheme-list\n"
"                        Exclude the specified URI schemes"
msgstr ""
"--தவிர்க்க-திட்டங்கள் திட்டம்-பட்டியல் \n"
"குறிப்பிட்ட யூரி திட்டங்களை விலக்கவும்"

#: tools/ippfind.c:2003
msgid ""
"--exec utility [argument ...] ;\n"
"                        Execute program if true"
msgstr ""
"--exec பயன்பாடு [வாதம் ...] ; \n"
"உண்மை என்றால் நிரலை இயக்கவும்"

#: tools/ippfind.c:2023
msgid "--false                 Always false"
msgstr "--false எப்போதும் பொய்"

#: tools/cups-oauth.c:679 tools/cups-x509.c:970
msgid "--help                         Show this help"
msgstr "--இந்த உதவியைக் காட்டுங்கள்"

#: tools/ippeveprinter.c:7727
msgid "--help                  Show program help"
msgstr "--உதவி நிரல் உதவியைக் காட்டு"

#: tools/ipptool.c:6599
msgid "--help                  Show this help"
msgstr "--இந்த உதவியைக் காட்டுங்கள்"

#: systemv/cupsaccept.c:246
msgid "--hold                  Hold new jobs"
msgstr "--பிடி புதிய வேலைகளை வைத்திருங்கள்"

#: tools/ippfind.c:2005
msgid "--host regex            Match hostname to regular expression"
msgstr "--host வழக்கவெளி ஓச்ட்பெயரை வழக்கமான வெளிப்பாட்டுடன் பொருத்தவும்"

#: systemv/lpinfo.c:503
msgid ""
"--include-schemes scheme-list\n"
"                        Include only the specified URI schemes"
msgstr ""
"--திட்டங்கள் திட்டப் பட்டியல் \n"
"குறிப்பிட்ட யூரி திட்டங்களை மட்டும் சேர்க்கவும்"

#: tools/ipptool.c:6600
msgid "--ippserver filename    Produce ippserver attribute file"
msgstr "--ippserver கோப்பு பெயர் ippserver பண்புக் கோப்பை உருவாக்கவும்"

#: systemv/lpinfo.c:505
msgid "--language locale       Show models matching the given locale"
msgstr "--language மொழி கொடுக்கப்பட்ட மொழிக்கு பொருந்தும் மாதிரிகளைக் காட்டு"

#: tools/ippfind.c:2006
msgid "--literal-name name     Match service name to literal name value"
msgstr ""
"--literal-name பெயர் சேவையின் பெயரை நேரடியான பெயர் மதிப்புடன் பொருத்தவும்"

#: tools/ippfind.c:2007
msgid "--local                 True if service is local"
msgstr "--local பணி உள்ளக என்றால் சரி"

#: tools/ippfind.c:2008
msgid "--ls                    List attributes"
msgstr "--ls பட்டியல் பண்புக்கூறுகள்"

#: systemv/lpinfo.c:506
msgid "--make-and-model name   Show models matching the given make and model name"
msgstr ""
"--make-and-model பெயர் கொடுக்கப்பட்ட தயாரிப்பு மற்றும் மாதிரிப் பெயருடன் பொருந்தும் "
"மாதிரிகளைக் காட்டு"

#: tools/ippfind.c:2009
msgid "--name regex            Match service name to regular expression"
msgstr "--பெயர் வழக்கவெளி சேவையின் பெயரை வழக்கமான வெளிப்பாட்டுடன் பொருத்தவும்"

#: tools/ippeveprinter.c:7728
msgid "--no-web-forms          Disable web forms for media and supplies"
msgstr "--no-web-forms மீடியா மற்றும் சப்ளைகளுக்கான இணைய படிவங்களை முடக்கு"

#: tools/ippfind.c:2022
msgid "--not expression        Unary NOT of expression"
msgstr "--இல்லை வெளிப்பாடு யூனரி இல்லை வெளிப்பாடு"

#: tools/ippeveprinter.c:7729
msgid "--pam-service service   Use the named PAM service"
msgstr "--pam-service பணி பெயரிடப்பட்ட பாம் சேவையைப் பயன்படுத்தவும்"

#: tools/ippfind.c:2010
msgid "--path regex            Match resource path to regular expression"
msgstr "--path வழக்கவெளி வழக்கமான வெளிப்பாட்டிற்கு ஆதார பாதையை பொருத்து"

#: tools/cups-x509.c:971
msgid "--pin                          Pin certificate found by client command"
msgstr "--pin பின் சான்றிதழ் கிளையன்ட் கட்டளை மூலம் கண்டறியப்பட்டது"

#: tools/ippfind.c:2011
msgid "--port number[-number]  Match port to number or range"
msgstr "--போர்ட் எண்[-எண்] எண் அல்லது வரம்புடன் போர்ட்டை பொருத்தவும்"

#: tools/ippfind.c:2012
msgid "--print                 Print URI if true"
msgstr "--சரியானால் யூரி ஐ அச்சிடுக"

#: tools/ippfind.c:2013
msgid "--print-name            Print service name if true"
msgstr "--print-name உண்மை எனில் அச்சு சேவையின் பெயர்"

#: systemv/lpinfo.c:507
msgid "--product name          Show models matching the given PostScript product"
msgstr ""
"--தயாரிப்பு பெயர் கொடுக்கப்பட்ட போச்ட்ச்கிரிப்ட் தயாரிப்புடன் பொருந்தும் மாதிரிகளைக் காட்டு"

#: tools/ippfind.c:2014
msgid "--quiet                 Quietly report match via exit code"
msgstr "--quiet அமைதியாக வெளியேறும் குறியீடு மூலம் பொருத்தத்தைப் புகாரளிக்கவும்"

#: systemv/cupsaccept.c:248
msgid "--release               Release previously held jobs"
msgstr "--release ரிலீச் முன்பு இருந்த வேலைகள்"

#: tools/ippfind.c:2015
msgid "--remote                True if service is remote"
msgstr "--remote பணி தொலைவில் இருந்தால் சரி"

#: tools/cups-x509.c:972
msgid "--require-ca                   Require CA-signed certificate for client command"
msgstr "--require-ca கிளையன்ட் கட்டளைக்கு CA-கையொப்பமிடப்பட்ட சான்றிதழ் தேவை"

#: tools/ipptool.c:6601
msgid ""
"--stop-after-include-error\n"
"                        Stop tests after a failed INCLUDE"
msgstr ""
"--நிறுத்த-பிறகு-சேர்க்கும்-பிழை \n"
"தோல்வியுற்ற பிறகு சோதனைகளை நிறுத்தவும்"

#: systemv/lpinfo.c:508
msgid "--timeout seconds       Specify the maximum number of seconds to discover devices"
msgstr ""
"--timeout நொடிகள் சாதனங்களைக் கண்டறிய அதிகபட்ச வினாடிகளின் எண்ணிக்கையைக் குறிப்பிடவும்"

#: tools/ippfind.c:2024
msgid "--true                  Always true"
msgstr "--உண்மை எப்போதும் உண்மை"

#: tools/ippfind.c:2016
msgid "--txt key               True if the TXT record contains the key"
msgstr "--txt விசை TXT பதிவில் விசை இருந்தால் சரி"

#: tools/ippfind.c:2017
msgid "--txt-* regex           Match TXT record key to regular expression"
msgstr "--txt-* வழக்கவெளி TXT பதிவு விசையை வழக்கமான வெளிப்பாட்டுடன் பொருத்தவும்"

#: tools/ippfind.c:2018
msgid "--uri regex             Match URI to regular expression"
msgstr "--uri வழக்கவெளி URIஐ வழக்கமான வெளிப்பாட்டுடன் பொருத்து"

#: tools/ipptool.c:6603
msgid "--user-agent USER-AGENT Set the HTTP User-Agent string"
msgstr "--user-agent USER-AGENT HTTP பயனர் முகவர் சரத்தை அமைக்கவும்"

#: tools/cups-oauth.c:680 tools/cups-x509.c:973
