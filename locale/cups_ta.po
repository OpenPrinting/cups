msgstr "      **தோல்வி** PPD கோப்பை திறக்க முடியவில்லை - %s வரி %d இல்."

#: systemv/cupstestppd.c:1475
#, c-format
msgid "    %d ERRORS FOUND"
msgstr "    %d பிழைகள் காணப்பட்டன"

#: systemv/cupstestppd.c:1477
msgid "    NO ERRORS FOUND"
msgstr "    பிழைகள் எதுவும் இல்லை"

#: ppdc/ppdc.cxx:444
msgid "  --cr                    End lines with CR (Mac OS 9)."
msgstr "  --cr இறுதி வரிகள் சிஆர் உடன் (Mac OS 9)."

#: ppdc/ppdc.cxx:446
msgid "  --crlf                  End lines with CR + LF (Windows)."
msgstr "  --crlf இறுதிக் கோடுகள் சிஆர் + எல்எஃப் (Windows) உடன்."

#: ppdc/ppdc.cxx:448
msgid "  --lf                    End lines with LF (UNIX/Linux/macOS)."
msgstr "  --lf எல்எஃப் (UNIX/Linux/macOS) உடன் இறுதி வரிகள்."

#: scheduler/cupsfilter.c:1549
msgid "  --list-all              List all filters with the MIME media types."
msgstr ""
"  --list-all அனைத்து வடிப்பான்களையும் MIME மீடியா வகைகளுடன் பட்டியலிடவும்."

#: scheduler/cupsfilter.c:1550
msgid "  --list-filters          List filters that will be used."
msgstr "  --list-filters பயன்படுத்தப்படும் பட்டியல் வடிகட்டிகள்."

#: scheduler/cupsfilter.c:1551
msgid "  -D                      Remove the input file when finished."
msgstr "  -D முடிந்ததும் உள்ளீட்டு கோப்பை அகற்றவும்."

#: ppdc/ppdc.cxx:427 ppdc/ppdhtml.cxx:174 ppdc/ppdpo.cxx:244
msgid "  -D name=value           Set named variable to value."
msgstr "  -D பெயர்=மதிப்பு மதிப்புக்கு மாறி பெயரிடப்பட்டது."

#: ppdc/ppdc.cxx:429 ppdc/ppdhtml.cxx:176 ppdc/ppdi.cxx:120 ppdc/ppdpo.cxx:246
msgid "  -I include-dir          Add include directory to search path."
msgstr "  -ஐ உள்ளடக்கியது-தேடல் பாதைக்கான கோப்பகத்தைச் சேர்."

#: scheduler/cupsfilter.c:1552
msgid "  -P FILENAME.ppd         Set PPD file."
msgstr "  -P FILENAME.ppd PPD கோப்பை அமைக்கவும்."

#: scheduler/cupsfilter.c:1553
msgid "  -U USERNAME             Specify username."
msgstr "  -U USERNAME பயனர் பெயரைக் குறிப்பிடவும்."

#: ppdc/ppdc.cxx:431
msgid "  -c catalog.po           Load the specified message catalog."
msgstr "  -c catalog.po குறிப்பிட்ட செய்தி அட்டவணையை ஏற்றவும்."

#: scheduler/cupsfilter.c:1554
msgid "  -c cups-files.conf      Set cups-files.conf file to use."
msgstr "  -c cups-files.conf பயன்படுத்த கப்ச்-files.conf கோப்பை அமைக்கவும்."

#: scheduler/cupsfilter.c:1555
msgid "  -d PRINTER              Use the named printer."
msgstr "  -d பிரிண்டர் பெயரிடப்பட்ட அச்சுப்பொறியைப் பயன்படுத்தவும்."

#: ppdc/ppdc.cxx:433
msgid "  -d output-dir           Specify the output directory."
msgstr "  -d output-dir வெளியீட்டு கோப்பகத்தைக் குறிப்பிடவும்."

#: scheduler/cupsfilter.c:1556
msgid "  -e                      Use every filter from the PPD file."
msgstr "  -e PPD கோப்பிலிருந்து ஒவ்வொரு வடிப்பானையும் பயன்படுத்தவும்."

#: scheduler/cupsfilter.c:1557
msgid "  -i MIME/TYPE            Set input MIME type (otherwise auto-typed)."
msgstr "  -i MIME/TYPE அமை உள்ளீடு MIME வகை (இல்லையெனில் தானாக தட்டச்சு)."

#: scheduler/cupsfilter.c:1558
msgid "  -j JOB-ID[,N]           Filter file N from the specified job (default is file 1)."
msgstr ""
"  -j JOB-ID[,N] குறிப்பிட்ட வேலையிலிருந்து N கோப்பை வடிகட்டவும் (இயல்பு கோப்பு 1)."

#: ppdc/ppdc.cxx:435
msgid "  -l lang[,lang,...]      Specify the output language(s) (locale)."
msgstr "  -l lang[,lang,...] வெளியீட்டு மொழி(களை) (உள்ளூர்) குறிப்பிடவும்."

#: ppdc/ppdc.cxx:437
msgid "  -m                      Use the ModelName value as the filename."
msgstr "  -m கோப்பின் பெயராக ModelName மதிப்பைப் பயன்படுத்தவும்."

#: scheduler/cupsfilter.c:1559
msgid "  -m MIME/TYPE            Set output MIME type (otherwise application/pdf)."
msgstr ""
"  -m MIME/TYPE வெளியீடு MIME வகையை அமைக்கவும் (இல்லையெனில் பயன்பாடு/pdf)."

#: scheduler/cupsfilter.c:1560
msgid "  -n COPIES               Set number of copies."
msgstr "  -n பிரதிகள் பிரதிகளின் எண்ணிக்கையை அமைக்கவும்."

#: scheduler/cupsfilter.c:1561
msgid "  -o NAME=VALUE           Set option(s)."
msgstr "  -o NAME=VALUE செட் விருப்பம்(கள்)."

#: ppdc/ppdi.cxx:122
msgid "  -o filename.drv         Set driver information file (otherwise ppdi.drv)."
msgstr ""
"  -o filename.drv இயக்கி செய்தி கோப்பை அமைக்கவும் (இல்லையெனில் ppdi.drv)."

#: ppdc/ppdmerge.cxx:357
msgid "  -o filename.ppd[.gz]    Set output file (otherwise stdout)."
msgstr ""
"  -o filename.ppd[.gz] வெளியீட்டு கோப்பை அமைக்கவும் (இல்லையெனில் stdout)."

#: scheduler/cupsfilter.c:1562
msgid "  -p FILENAME.ppd         Set PPD file."
msgstr "  -p FILENAME.ppd PPD கோப்பை அமைக்கவும்."

#: ppdc/ppdc.cxx:439
msgid "  -t                      Test PPDs instead of generating them."
msgstr "  -t சோதனை PPDகளை உருவாக்குவதற்குப் பதிலாக."

#: scheduler/cupsfilter.c:1563
msgid "  -t TITLE                Set title."
msgstr "  -t TITLE தலைப்பு அமை."

#: scheduler/cupsfilter.c:1564
msgid "  -u                      Remove the PPD file when finished."
msgstr "  -u முடிந்ததும் PPD கோப்பை அகற்றவும்."

#: ppdc/ppdc.cxx:441 ppdc/ppdpo.cxx:248
msgid "  -v                      Be verbose."
msgstr "  -v வாய்மொழியாக இருங்கள்."

#: ppdc/ppdc.cxx:442
msgid "  -z                      Compress PPD files using GNU zip."
msgstr "  -z குனு சிப்பைப் பயன்படுத்தி PPD கோப்புகளை சுருக்கவும்."

