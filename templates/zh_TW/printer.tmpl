<H2 CLASS="title"><A HREF="{printer_uri_supported}">{printer_name}</A>
({printer_state=3?空閒:{printer_state=4?列印中:已暫停}},
{printer_is_accepting_jobs=0?拒絕作業:接受作業},
{server_is_sharing_printers=0?否:{printer_is_shared=0?否:}} 共享{default_name={printer_name}?, 伺服器預設:})</H2>

<FORM METHOD="POST" ACTION="{printer_uri_supported}" NAME="maintenance">
<INPUT TYPE="HIDDEN" NAME="org.cups.sid" VALUE="{$org.cups.sid}">
<SELECT NAME="OP" ONCHANGE="document.maintenance.submit();">
<OPTION VALUE="">維護</OPTION>
<OPTION VALUE="print-test-page">列印測試頁</OPTION>
{printer_commands~.*Clean.*?<OPTION VALUE="clean-print-heads">清潔列印頭</OPTION>:}
{printer_commands~.*PrintSelfTestPage.*?<OPTION VALUE="print-self-test-page">自己列印測試頁</OPTION>:}
{printer_state=5?<OPTION VALUE="start-printer">啟動列印機</OPTION>:<OPTION VALUE="stop-printer">暫停列印機</OPTION>}
{printer_is_accepting_jobs=0?<OPTION VALUE="accept-jobs">接受作業</OPTION>:<OPTION VALUE="reject-jobs">拒絕作業</OPTION>}
<OPTION VALUE="move-jobs">移動作業</OPTION>
<OPTION VALUE="cancel-jobs">取消作業</OPTION>
</SELECT>
<NOSCRIPT><INPUT TYPE="SUBMIT" VALUE="確定"></NOSCRIPT>
</FORM>

<FORM METHOD="POST" ACTION="{admin_uri}" NAME="administration">
<INPUT TYPE="HIDDEN" NAME="org.cups.sid" VALUE="{$org.cups.sid}">
<INPUT TYPE="HIDDEN" NAME="printer_name" VALUE="{printer_name}">
<SELECT NAME="OP" ONCHANGE="document.administration.submit();">
<OPTION VALUE="">管理</OPTION>
<OPTION VALUE="modify-printer">修改列印機</OPTION>
<OPTION VALUE="delete-printer">刪除列印機</OPTION>
<OPTION VALUE="set-printer-options">設定預設選項</OPTION>
<OPTION VALUE="set-as-default">設為伺服器預設</OPTION>
<OPTION VALUE="set-allowed-users">設定允許的使用者</OPTION>
</SELECT>
<NOSCRIPT><INPUT TYPE="SUBMIT" VALUE="確定"></NOSCRIPT>
</FORM>

<TABLE SUMMARY="{printer_name}">
<TR><TH ALIGN="RIGHT" VALIGN="TOP">說明:</TH><TD>{printer_info}</TD></TR>
<TR><TH ALIGN="RIGHT" VALIGN="TOP">位置:</TH><TD>{printer_location}</TD></TR>
<TR><TH ALIGN="RIGHT" VALIGN="TOP">列印機驅動:</TH><TD>{printer_make_and_model} ({color_supported=1?彩色:黑白}{sides_supported=one-sided?:, 雙面})<BR>
<TR><TH ALIGN="RIGHT" VALIGN="TOP">連線:</TH><TD>{device_uri}</TD></TR>
<TR><TH ALIGN="RIGHT" VALIGN="TOP">預設設定:</TH><TD>封面={job_sheets_default}
介質={media_default?{media_default}:未知}
{sides_default?雙面={sides_default}:}</TD></TR>
</TABLE>
